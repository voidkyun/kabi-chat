APP_DOMAIN=chat.example.com
ACME_EMAIL=ops@example.com

POSTGRES_DB=kabi_chat
POSTGRES_USER=kabi_chat
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgresql://kabi_chat:replace-me@db:5432/kabi_chat

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-me
DJANGO_ALLOWED_HOSTS=chat.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://chat.example.com
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=1
DJANGO_USE_PROXY_SSL_HEADER=1
DJANGO_USE_X_FORWARDED_HOST=1
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0

DISCORD_CLIENT_ID=replace-me
DISCORD_CLIENT_SECRET=replace-me
DISCORD_REDIRECT_URI=https://chat.example.com/auth/discord/callback
JWT_SIGNING_KEY=replace-me
AUTH_FRONTEND_CALLBACK_URL=https://chat.example.com/login/callback
AUTH_COOKIE_SECURE=1
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_DOMAIN=chat.example.com
AUTH_COOKIE_PATH=/

VITE_API_BASE_URL=
