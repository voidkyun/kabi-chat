aws_region = "ap-northeast-1"

vpc_cidr = "10.20.0.0/16"

availability_zones = [
  "ap-northeast-1a",
  "ap-northeast-1c",
]

public_subnet_cidrs = [
  "10.20.0.0/24",
  "10.20.1.0/24",
]

private_app_subnet_cidrs = [
  "10.20.10.0/24",
  "10.20.11.0/24",
]

private_db_subnet_cidrs = [
  "10.20.20.0/24",
  "10.20.21.0/24",
]

backend_image_tag     = "stable"
backend_desired_count = 2
backend_cpu           = 1024
backend_memory        = 2048

acm_certificate_arn        = "arn:aws:acm:ap-northeast-1:123456789012:certificate/replace-me"
db_instance_class          = "db.t4g.small"
db_allocated_storage       = 50
db_multi_az                = true
db_backup_retention_period = 14
db_deletion_protection     = true
db_skip_final_snapshot     = true

app_environment_variables = {
  AUTH_FRONTEND_CALLBACK_URL = "https://app.example.com/login/callback"
  DISCORD_CLIENT_ID          = "replace-me"
  DISCORD_REDIRECT_URI       = "https://api.example.com/auth/discord/callback"
}
