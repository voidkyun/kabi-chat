# Shared
COMPOSE_PROJECT_NAME=kabi-chat

# PostgreSQL
POSTGRES_DB=kabi_chat
POSTGRES_USER=kabi_chat
POSTGRES_PASSWORD=kabi_chat
POSTGRES_PORT=5432

# Backend
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=replace-me
DATABASE_URL=postgresql://kabi_chat:kabi_chat@db:5432/kabi_chat
DISCORD_CLIENT_ID=replace-me
DISCORD_CLIENT_SECRET=replace-me
DISCORD_REDIRECT_URI=http://localhost:8000/auth/discord/callback
JWT_SIGNING_KEY=replace-me

# Frontend
VITE_API_BASE_URL=http://localhost:8000
