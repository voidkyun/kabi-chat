# Shared
COMPOSE_PROJECT_NAME=kabi-chat

# PostgreSQL
POSTGRES_DB=kabi_chat
POSTGRES_USER=kabi_chat
POSTGRES_PASSWORD=kabi_chat
POSTGRES_PORT=5432

# Backend
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=replace-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:8000
DJANGO_CSRF_COOKIE_SECURE=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=0
DJANGO_USE_PROXY_SSL_HEADER=0
DJANGO_USE_X_FORWARDED_HOST=0
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0
DATABASE_URL=postgresql://kabi_chat:kabi_chat@db:5432/kabi_chat
DISCORD_CLIENT_ID=replace-me
DISCORD_CLIENT_SECRET=replace-me
DISCORD_REDIRECT_URI=http://localhost:8000/auth/discord/callback
JWT_SIGNING_KEY=replace-me
AUTH_FRONTEND_CALLBACK_URL=http://localhost:5173/login/callback

# Frontend
VITE_API_BASE_URL=http://localhost:8000
